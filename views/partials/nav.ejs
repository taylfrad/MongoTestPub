<nav class="nav">
  <div class="nav-inner">
    <a href="/" class="nav-brand">Message Board</a>

    <div class="hidden sm:flex items-center gap-0.5 ml-2">
      <a href="/topics" class="nav-link">Topics</a>
      <a href="/stats" class="nav-link">Stats</a>
      <% if (currentUser) { %>
        <a href="/notifications" class="nav-link flex items-center gap-1">
          Notifications
          <% if (typeof unreadCount !== 'undefined' && unreadCount > 0) { %>
            <span class="badge badge-pulse"><%= unreadCount %></span>
          <% } %>
        </a>
      <% } %>
    </div>

    <div class="ml-auto flex items-center gap-2">
      <% /* Mobile: collapsed dropdown so the nav doesn't overflow on phones. */ %>
      <details class="theme-menu sm:hidden">
        <summary class="theme-menu-trigger" aria-label="Theme">
          <svg class="theme-menu-icon theme-menu-icon-light theme-icon-sun" viewBox="0 0 16 16" fill="#FFB800" stroke="#FFB800" stroke-width="1.4" stroke-linecap="round">
            <circle cx="8" cy="8" r="3" fill="#FFB800"/>
            <path fill="none" d="M8 1v2M8 13v2M1 8h2M13 8h2M3.05 3.05l1.4 1.4M11.55 11.55l1.4 1.4M3.05 12.95l1.4-1.4M11.55 4.45l1.4-1.4"/>
          </svg>
          <svg class="theme-menu-icon theme-menu-icon-system" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round">
            <rect x="2" y="3" width="12" height="8.5" rx="1.5"/>
            <path d="M6 14h4M8 11.5V14"/>
          </svg>
          <svg class="theme-menu-icon theme-menu-icon-dark theme-icon-moon" viewBox="0 0 16 16" fill="currentColor" stroke="none">
            <path d="M13.2 9.6A5.2 5.2 0 0 1 6.4 2.8a5.4 5.4 0 1 0 6.8 6.8z"/>
          </svg>
        </summary>
        <div class="theme-menu-panel theme-picker" role="menu" aria-label="Theme">
          <button type="button" data-theme="light" role="menuitem">
            <svg class="theme-icon-sun" viewBox="0 0 16 16" fill="#FFB800" stroke="#FFB800" stroke-width="1.4" stroke-linecap="round">
              <circle cx="8" cy="8" r="3" fill="#FFB800"/>
              <path fill="none" d="M8 1v2M8 13v2M1 8h2M13 8h2M3.05 3.05l1.4 1.4M11.55 11.55l1.4 1.4M3.05 12.95l1.4-1.4M11.55 4.45l1.4-1.4"/>
            </svg>
            <span>Light</span>
          </button>
          <button type="button" data-theme="system" role="menuitem">
            <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round">
              <rect x="2" y="3" width="12" height="8.5" rx="1.5"/>
              <path d="M6 14h4M8 11.5V14"/>
            </svg>
            <span>Auto</span>
          </button>
          <button type="button" data-theme="dark" role="menuitem">
            <svg class="theme-icon-moon" viewBox="0 0 16 16" fill="currentColor" stroke="none">
              <path d="M13.2 9.6A5.2 5.2 0 0 1 6.4 2.8a5.4 5.4 0 1 0 6.8 6.8z"/>
            </svg>
            <span>Dark</span>
          </button>
        </div>
      </details>

      <% /* Desktop: inline segmented pill. */ %>
      <div class="theme-picker hidden sm:inline-flex" role="group" aria-label="Theme">
        <button type="button" data-theme="light" aria-label="Light">
          <svg class="theme-icon-sun" viewBox="0 0 16 16" fill="#FFB800" stroke="#FFB800" stroke-width="1.4" stroke-linecap="round">
            <circle cx="8" cy="8" r="3" fill="#FFB800"/>
            <path fill="none" d="M8 1v2M8 13v2M1 8h2M13 8h2M3.05 3.05l1.4 1.4M11.55 11.55l1.4 1.4M3.05 12.95l1.4-1.4M11.55 4.45l1.4-1.4"/>
          </svg>
          <span class="hidden md:inline">Light</span>
        </button>
        <button type="button" data-theme="system" aria-label="Auto">
          <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round">
            <rect x="2" y="3" width="12" height="8.5" rx="1.5"/>
            <path d="M6 14h4M8 11.5V14"/>
          </svg>
          <span class="hidden md:inline">Auto</span>
        </button>
        <button type="button" data-theme="dark" aria-label="Dark">
          <svg class="theme-icon-moon" viewBox="0 0 16 16" fill="currentColor" stroke="none">
            <path d="M13.2 9.6A5.2 5.2 0 0 1 6.4 2.8a5.4 5.4 0 1 0 6.8 6.8z"/>
          </svg>
          <span class="hidden md:inline">Dark</span>
        </button>
      </div>

      <% if (currentUser) { %>
        <span class="text-tertiary text-sm hidden md:inline">
          <%= currentUser.username %>
        </span>
        <form method="POST" action="/logout" class="inline"
              data-confirm="You'll be signed out of Message Board."
              data-confirm-title="Sign out?"
              data-confirm-label="Sign out"
              data-confirm-destructive="true">
          <button type="submit" class="btn btn-danger-ghost btn-sm">Sign out</button>
        </form>
      <% } else { %>
        <a href="/login" class="btn btn-ghost btn-sm hidden sm:inline-flex">Sign in</a>
        <a href="/register" class="btn btn-primary btn-sm">Sign up</a>
      <% } %>
    </div>
  </div>
</nav>
