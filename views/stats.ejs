<div class="flex items-end justify-between mb-8 gap-4">
  <div>
    <p class="text-xs uppercase tracking-[0.16em] text-tertiary mb-1">Usage</p>
    <h1 class="font-display text-4xl sm:text-5xl tracking-tight leading-[1.05]">Stats.</h1>
  </div>
  <div class="text-right text-sm">
    <p class="mono text-xl tabular"><span data-count="<%= totalAccesses %>"><%= totalAccesses %></span></p>
    <p class="text-xs text-tertiary">total access<%= totalAccesses === 1 ? '' : 'es' %> · <span data-count="<%= totalMessages %>"><%= totalMessages %></span> message<%= totalMessages === 1 ? '' : 's' %></p>
  </div>
</div>

<% if (topics.length === 0) { %>
  <div class="card card-body text-center text-tertiary">No topics yet.</div>
<% } else { %>
  <div class="card card-flat overflow-hidden">
    <div class="grid grid-cols-[28px_1fr_56px_72px] sm:grid-cols-[32px_1fr_72px_84px] gap-4 px-5 py-3 text-xs uppercase tracking-[0.1em] text-tertiary font-medium border-b border-hair">
      <span>#</span>
      <span>Topic</span>
      <span class="text-right">Subs</span>
      <span class="text-right">Views</span>
    </div>
    <% topics.forEach(function (t, i) { %>
      <div class="grid grid-cols-[28px_1fr_56px_72px] sm:grid-cols-[32px_1fr_72px_84px] gap-4 px-5 py-3.5 items-baseline reveal <%= i === topics.length - 1 ? '' : 'border-b border-hair' %>">
        <span class="text-quaternary mono text-sm"><%= i + 1 %></span>
        <div class="min-w-0">
          <a href="/topics/<%= t._id %>" class="font-semibold hover:opacity-70 transition-opacity"><%= t.title %></a>
          <p class="text-xs text-tertiary mt-0.5">
            by <%= t.author ? t.author.username : '(deleted)' %>
          </p>
        </div>
        <span class="text-right mono text-sm tabular-nums"><%= (t.subscribers || []).length %></span>
        <span class="text-right mono text-sm tabular-nums font-semibold" data-count="<%= t.accessCount || 0 %>"><%= t.accessCount || 0 %></span>
      </div>
    <% }) %>
  </div>
<% } %>
