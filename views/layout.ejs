<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#F2F2F7" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#000000" media="(prefers-color-scheme: dark)" />
    <title><%= typeof title !== 'undefined' ? title : 'MessageBoard' %> · MessageBoard</title>

    <script>
      // Resolve theme before first paint to avoid flash.
      (function () {
        try {
          var pref = localStorage.getItem('theme-pref') || 'system';
          var resolved = pref === 'system'
            ? (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light')
            : pref;
          document.documentElement.setAttribute('data-theme', resolved);
          document.documentElement.setAttribute('data-theme-pref', pref);
        } catch (e) {
          document.documentElement.setAttribute('data-theme', 'light');
        }
      })();
    </script>

    <link rel="preload" as="style" href="/css/app.css?v=<%= assetVersion %>" />
    <link rel="stylesheet" href="/css/app.css?v=<%= assetVersion %>" />
    <script src="https://cdn.tailwindcss.com"></script>
  </head>
  <body>
    <%- include('partials/nav') %>
    <main class="wrap">
      <%- body %>
    </main>

    <button type="button" id="scroll-top" class="scroll-top" aria-label="Scroll to top">
      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor"
           stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M4 10l4-4 4 4" />
      </svg>
    </button>

    <dialog id="confirm-dialog" class="confirm" aria-labelledby="confirm-title">
      <div class="confirm-body-wrap">
        <h3 id="confirm-title" class="confirm-title">Are you sure?</h3>
        <p id="confirm-message" class="confirm-message"></p>
        <div class="confirm-actions">
          <button type="button" class="btn btn-secondary" data-confirm-action="cancel">Cancel</button>
          <button type="button" class="btn btn-primary" data-confirm-action="ok">Confirm</button>
        </div>
      </div>
    </dialog>

    <script>
      // Theme picker controller.
      (function () {
        var media = window.matchMedia('(prefers-color-scheme: dark)');

        function apply(pref) {
          var resolved = pref === 'system'
            ? (media.matches ? 'dark' : 'light')
            : pref;
          document.documentElement.setAttribute('data-theme', resolved);
          document.documentElement.setAttribute('data-theme-pref', pref);
          try { localStorage.setItem('theme-pref', pref); } catch (e) {}
          document.querySelectorAll('.theme-picker button').forEach(function (b) {
            b.setAttribute('aria-pressed', String(b.dataset.theme === pref));
          });
        }

        document.addEventListener('click', function (e) {
          var btn = e.target.closest('.theme-picker button');
          if (!btn) return;
          apply(btn.dataset.theme);
        });

        if (media.addEventListener) {
          media.addEventListener('change', function () {
            var pref = document.documentElement.getAttribute('data-theme-pref') || 'system';
            if (pref === 'system') apply('system');
          });
        }

        var pref = document.documentElement.getAttribute('data-theme-pref') || 'system';
        document.querySelectorAll('.theme-picker button').forEach(function (b) {
          b.setAttribute('aria-pressed', String(b.dataset.theme === pref));
        });
      })();

      // Scroll-reveal: fade + lift elements with class "reveal" as they enter view.
      (function () {
        var els = document.querySelectorAll('.reveal');
        if (!els.length) return;
        if (!('IntersectionObserver' in window) ||
            window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          els.forEach(function (el) { el.classList.add('in'); });
          return;
        }
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting) {
              e.target.classList.add('in');
              io.unobserve(e.target);
            }
          });
        }, { rootMargin: '0px 0px -60px 0px', threshold: 0.08 });
        els.forEach(function (el) { io.observe(el); });
      })();

      // Count-up: [data-count] numbers tick from 0 to their target when in view.
      (function () {
        var nodes = document.querySelectorAll('[data-count]');
        if (!nodes.length) return;
        var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        function tick(el) {
          var target = parseInt(el.getAttribute('data-count'), 10) || 0;
          if (reduce) { el.textContent = target.toLocaleString(); return; }
          var duration = Math.min(1200, 300 + target * 40);
          var start = performance.now();
          function frame(now) {
            var t = Math.min(1, (now - start) / duration);
            var eased = 1 - Math.pow(1 - t, 3);
            el.textContent = Math.floor(eased * target).toLocaleString();
            if (t < 1) requestAnimationFrame(frame);
            else el.textContent = target.toLocaleString();
          }
          el.textContent = '0';
          requestAnimationFrame(frame);
        }

        if (!('IntersectionObserver' in window)) {
          nodes.forEach(tick);
          return;
        }
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting) { tick(e.target); io.unobserve(e.target); }
          });
        }, { threshold: 0.4 });
        nodes.forEach(function (el) { io.observe(el); });
      })();

      // Scroll-to-top button.
      (function () {
        var btn = document.getElementById('scroll-top');
        if (!btn) return;
        var threshold = 240;
        var ticking = false;
        function update() {
          var show = (window.scrollY || window.pageYOffset) > threshold;
          btn.classList.toggle('visible', show);
          ticking = false;
        }
        window.addEventListener('scroll', function () {
          if (!ticking) {
            requestAnimationFrame(update);
            ticking = true;
          }
        }, { passive: true });
        btn.addEventListener('click', function () {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
        update();
      })();

      // Timestamp formatter — renders every <time class="ts"> in the user's
      // local timezone with Apple Messages-style smart relative formatting.
      (function () {
        function timePart(d) {
          return d.toLocaleTimeString(undefined, { hour: 'numeric', minute: '2-digit' });
        }

        function smart(d) {
          var now = new Date();
          var diffMs = now - d;
          var diffMin = Math.floor(diffMs / 60000);

          var sameDay = now.toDateString() === d.toDateString();
          var ydObj = new Date(now); ydObj.setDate(ydObj.getDate() - 1);
          var isYesterday = ydObj.toDateString() === d.toDateString();
          var withinWeek = diffMs >= 0 && diffMs < 7 * 86400000;

          if (diffMin < 1 && diffMs >= 0) return 'just now';
          if (diffMin < 60 && diffMs >= 0) return diffMin + ' min ago';
          if (sameDay) return timePart(d);
          if (isYesterday) return 'Yesterday ' + timePart(d);
          if (withinWeek) {
            return d.toLocaleDateString(undefined, { weekday: 'short' }) + ' ' + timePart(d);
          }
          if (d.getFullYear() === now.getFullYear()) {
            return d.toLocaleDateString(undefined, { month: 'short', day: 'numeric' });
          }
          return d.toLocaleDateString(undefined, { year: 'numeric', month: 'short', day: 'numeric' });
        }

        function full(d) {
          return d.toLocaleString(undefined, {
            year: 'numeric', month: 'short', day: 'numeric',
            hour: 'numeric', minute: '2-digit',
            timeZoneName: 'short'
          });
        }

        function renderAll() {
          document.querySelectorAll('time.ts').forEach(function (el) {
            var iso = el.getAttribute('datetime');
            if (!iso) return;
            var d = new Date(iso);
            if (isNaN(d.getTime())) return;
            el.textContent = smart(d);
            el.title = full(d);
          });
        }

        renderAll();
        setInterval(renderAll, 60000);
      })();

      // Confirmation dialog.
      (function () {
        var dlg = document.getElementById('confirm-dialog');
        if (!dlg || typeof dlg.showModal !== 'function') return;
        var titleEl   = dlg.querySelector('#confirm-title');
        var msgEl     = dlg.querySelector('#confirm-message');
        var okBtn     = dlg.querySelector('[data-confirm-action="ok"]');
        var cancelBtn = dlg.querySelector('[data-confirm-action="cancel"]');
        var pending = null;

        function open(form) {
          pending = form;
          titleEl.textContent = form.dataset.confirmTitle || 'Are you sure?';
          msgEl.textContent = form.dataset.confirm || '';
          var destructive = form.dataset.confirmDestructive === 'true';
          okBtn.textContent = form.dataset.confirmLabel || (destructive ? 'Delete' : 'Confirm');
          okBtn.className = 'btn ' + (destructive ? 'btn-destructive' : 'btn-primary');
          dlg.showModal();
          (destructive ? cancelBtn : okBtn).focus();
        }

        function close(result) {
          if (!pending) return;
          var form = pending;
          pending = null;
          dlg.close();
          if (result === 'ok') {
            form.dataset.confirmed = 'true';
            form.submit();
          }
        }

        document.addEventListener('submit', function (e) {
          var form = e.target.closest('form[data-confirm]');
          if (!form) return;
          if (form.dataset.confirmed === 'true') return;
          e.preventDefault();
          open(form);
        });

        okBtn.addEventListener('click', function () { close('ok'); });
        cancelBtn.addEventListener('click', function () { close('cancel'); });
        dlg.addEventListener('cancel', function () { close('cancel'); });
        dlg.addEventListener('click', function (e) {
          var r = dlg.getBoundingClientRect();
          var inside = e.clientX >= r.left && e.clientX <= r.right &&
                       e.clientY >= r.top  && e.clientY <= r.bottom;
          if (!inside) close('cancel');
        });
      })();
    </script>
  </body>
</html>
