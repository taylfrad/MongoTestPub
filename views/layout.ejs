<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#F2F2F7" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#000000" media="(prefers-color-scheme: dark)" />
    <title><%= typeof title !== 'undefined' ? title : 'MessageBoard' %> · MessageBoard</title>

    <script>
      // Resolve theme before first paint to avoid flash.
      (function () {
        try {
          var pref = localStorage.getItem('theme-pref') || 'system';
          var resolved = pref === 'system'
            ? (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light')
            : pref;
          document.documentElement.setAttribute('data-theme', resolved);
          document.documentElement.setAttribute('data-theme-pref', pref);
        } catch (e) {
          document.documentElement.setAttribute('data-theme', 'light');
        }
      })();
    </script>

    <script src="https://cdn.tailwindcss.com"></script>

    <style>
      /* ══════════════════════════════════════════════════════════════
         Apple HIG — systemColors + SF Pro + proper depth
         ══════════════════════════════════════════════════════════════ */
      :root {
        /* Backgrounds (HIG: grouped backgrounds) */
        --bg:            #F2F2F7;          /* systemGroupedBackground light */
        --surface:       #FFFFFF;          /* secondarySystemGroupedBackground */
        --surface-2:     #F2F2F7;          /* tertiary / nested */
        --surface-3:     #FFFFFF;

        /* Labels (HIG: labelColor hierarchy) */
        --label-1:       #1D1D1F;          /* primary */
        --label-2:       rgba(60, 60, 67, 0.78);   /* secondary (boosted from 0.6 for web) */
        --label-3:       rgba(60, 60, 67, 0.58);   /* tertiary */
        --label-4:       rgba(60, 60, 67, 0.58);   /* quaternary — boosted for web legibility */

        /* Fills / separators (HIG) */
        --fill-1:        rgba(120, 120, 128, 0.20);
        --fill-2:        rgba(120, 120, 128, 0.16);
        --fill-3:        rgba(120, 120, 128, 0.12);
        --fill-4:        rgba(116, 116, 128, 0.08);
        --separator:     rgba(60, 60, 67, 0.29);   /* nonOpaqueSeparator */
        --border:        rgba(60, 60, 67, 0.12);
        --border-strong: rgba(60, 60, 67, 0.22);

        /* Accents (HIG systemColors) */
        --accent:        #007AFF;          /* systemBlue */
        --accent-hover:  #0A6DD6;
        --accent-soft:   rgba(0, 122, 255, 0.10);
        --accent-glow:   rgba(0, 122, 255, 0.18);
        --danger:        #FF3B30;          /* systemRed */
        --danger-soft:   rgba(255, 59, 48, 0.10);
        --success:       #34C759;          /* systemGreen */
        --warning:       #FF9500;          /* systemOrange */

        /* Glass */
        --glass:         rgba(242, 242, 247, 0.72);
        --glass-border:  rgba(60, 60, 67, 0.14);

        /* Layered depth shadows — Apple uses tight hairline + soft ambient */
        --shadow-xs:
          0 0 0 0.5px rgba(0, 0, 0, 0.08);
        --shadow-sm:
          0 0 0 0.5px rgba(0, 0, 0, 0.06),
          0 1px 2px rgba(0, 0, 0, 0.04),
          0 4px 12px -2px rgba(0, 0, 0, 0.05);
        --shadow-md:
          0 0 0 0.5px rgba(0, 0, 0, 0.06),
          0 2px 4px rgba(0, 0, 0, 0.03),
          0 12px 32px -8px rgba(0, 0, 0, 0.10);
        --shadow-lg:
          0 0 0 0.5px rgba(0, 0, 0, 0.08),
          0 24px 60px -12px rgba(0, 0, 0, 0.18);

        /* Inset highlight (blank on light — only needed for dark) */
        --inset-hl: 0 0 0 rgba(0, 0, 0, 0);

        /* Radii (Apple's continuous-curve feel, even if we can't easily do squircle) */
        --radius-xs: 6px;
        --radius-sm: 10px;
        --radius:    13px;   /* iOS card */
        --radius-lg: 18px;   /* big card */
        --radius-xl: 28px;   /* panel */

        --ease:        cubic-bezier(0.4, 0, 0.2, 1);
        --ease-spring: cubic-bezier(0.32, 0.72, 0, 1);

        color-scheme: light;
      }

      [data-theme='dark'] {
        /* iOS dark uses black base with elevated grays */
        --bg:            #000000;          /* systemBackground */
        --surface:       #1C1C1E;          /* secondarySystemBackground */
        --surface-2:     #2C2C2E;          /* tertiarySystemBackground */
        --surface-3:     #3A3A3C;

        --label-1:       #FFFFFF;
        --label-2:       rgba(235, 235, 245, 0.78);
        --label-3:       rgba(235, 235, 245, 0.58);
        --label-4:       rgba(235, 235, 245, 0.38);

        --fill-1:        rgba(120, 120, 128, 0.36);
        --fill-2:        rgba(120, 120, 128, 0.32);
        --fill-3:        rgba(118, 118, 128, 0.24);
        --fill-4:        rgba(118, 118, 128, 0.18);
        --separator:     rgba(84, 84, 88, 0.65);
        --border:        rgba(255, 255, 255, 0.09);
        --border-strong: rgba(255, 255, 255, 0.18);

        --accent:        #0A84FF;          /* systemBlue dark */
        --accent-hover:  #3B9DFF;
        --accent-soft:   rgba(10, 132, 255, 0.18);
        --accent-glow:   rgba(10, 132, 255, 0.28);
        --danger:        #FF453A;          /* systemRed dark */
        --danger-soft:   rgba(255, 69, 58, 0.18);
        --success:       #32D74B;
        --warning:       #FF9F0A;

        --glass:         rgba(28, 28, 30, 0.72);
        --glass-border:  rgba(255, 255, 255, 0.09);

        /* Dark mode: cards get an inset top highlight for dimensional pop */
        --shadow-xs:
          0 0 0 0.5px rgba(255, 255, 255, 0.06),
          inset 0 1px 0 rgba(255, 255, 255, 0.05);
        --shadow-sm:
          0 0 0 0.5px rgba(255, 255, 255, 0.06),
          inset 0 1px 0 rgba(255, 255, 255, 0.05),
          0 2px 6px rgba(0, 0, 0, 0.35),
          0 10px 24px -6px rgba(0, 0, 0, 0.5);
        --shadow-md:
          0 0 0 0.5px rgba(255, 255, 255, 0.07),
          inset 0 1px 0 rgba(255, 255, 255, 0.06),
          0 4px 10px rgba(0, 0, 0, 0.45),
          0 18px 40px -10px rgba(0, 0, 0, 0.6);
        --shadow-lg:
          0 0 0 0.5px rgba(255, 255, 255, 0.12),
          inset 0 1px 0 rgba(255, 255, 255, 0.08),
          0 36px 80px -16px rgba(0, 0, 0, 0.75);

        color-scheme: dark;
      }

      /* ─── Reset & base ─── */
      * { -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
      * { box-sizing: border-box; }

      html, body {
        background: var(--bg);
        color: var(--label-1);
        font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'SF Pro Display',
          'Helvetica Neue', 'Segoe UI', system-ui, sans-serif;
        font-size: 17px;
        line-height: 1.47;
        letter-spacing: -0.022em;
        font-optical-sizing: auto;
        text-rendering: optimizeLegibility;
        transition: background-color 0.28s var(--ease), color 0.28s var(--ease);
      }

      /* Subtle atmospheric glow in dark mode so the page isn't flat black. */
      body::before {
        content: '';
        position: fixed;
        inset: 0;
        pointer-events: none;
        background: radial-gradient(
          ellipse 80% 50% at 50% -10%,
          var(--accent-glow),
          transparent 70%
        );
        opacity: 0;
        transition: opacity 0.4s var(--ease);
        z-index: 0;
      }
      [data-theme='dark'] body::before { opacity: 0.65; }

      main, nav, dialog { position: relative; z-index: 1; }

      /* ─── Typography ─── */
      /* SF Pro Display takes over for sizes >= 20px on Apple platforms. */
      h1, h2, h3, h4, .display {
        font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display',
          'Helvetica Neue', 'Segoe UI', system-ui, sans-serif;
        letter-spacing: -0.028em;
        line-height: 1.08;
        color: var(--label-1);
      }

      .font-display {
        font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display',
          'Helvetica Neue', 'Segoe UI', system-ui, sans-serif;
        font-weight: 700;
        letter-spacing: -0.035em;
        line-height: 1.04;
        color: var(--label-1);
      }

      .mono {
        font-family: ui-monospace, 'SF Mono', 'Menlo', Consolas, 'Liberation Mono', monospace;
        font-feature-settings: 'tnum';
      }

      /* ─── Nav ─── */
      .nav {
        position: sticky;
        top: 0;
        z-index: 50;
        background: var(--glass);
        backdrop-filter: saturate(180%) blur(24px);
        -webkit-backdrop-filter: saturate(180%) blur(24px);
        border-bottom: 0.5px solid var(--glass-border);
      }
      .nav-inner {
        max-width: 1080px;
        margin: 0 auto;
        padding: 0.7rem 1.25rem;
        display: flex;
        align-items: center;
        gap: 1rem;
      }
      .nav-brand {
        font-family: inherit;
        font-weight: 600;
        font-size: 1.06rem;
        letter-spacing: -0.022em;
        color: var(--label-1);
        text-decoration: none;
      }
      .nav-link {
        font-size: 0.88rem;
        font-weight: 500;
        color: var(--label-2);
        text-decoration: none;
        padding: 0.42rem 0.78rem;
        border-radius: 980px;
        transition: color 0.18s var(--ease), background 0.18s var(--ease);
      }
      .nav-link:hover { color: var(--label-1); background: var(--fill-4); }

      /* ─── Buttons ─── */
      .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        padding: 0.58rem 1.15rem;
        font-family: inherit;
        font-size: 0.94rem;
        font-weight: 590;                /* SF Pro's "Semibold" */
        letter-spacing: -0.014em;
        border-radius: 980px;
        border: 1px solid transparent;
        cursor: pointer;
        white-space: nowrap;
        transition: transform 0.12s var(--ease-spring), background 0.2s var(--ease),
          color 0.2s var(--ease), border-color 0.2s var(--ease),
          box-shadow 0.2s var(--ease);
      }
      .btn:active { transform: scale(0.97); }
      .btn-sm { padding: 0.4rem 0.9rem; font-size: 0.82rem; }
      .btn-xs { padding: 0.28rem 0.7rem; font-size: 0.76rem; font-weight: 590; }

      .btn-primary {
        background: var(--accent);
        color: #fff;
        background-image: linear-gradient(180deg, rgba(255,255,255,0.12), rgba(255,255,255,0));
        box-shadow:
          0 0 0 0.5px rgba(0, 0, 0, 0.06),
          0 1px 2px rgba(0, 0, 0, 0.08),
          inset 0 1px 0 rgba(255, 255, 255, 0.18);
      }
      .btn-primary:hover { background-color: var(--accent-hover); }

      .btn-secondary {
        background: var(--surface);
        color: var(--label-1);
        border-color: var(--border-strong);
        box-shadow: var(--shadow-xs);
      }
      .btn-secondary:hover { background: var(--fill-4); }

      .btn-ghost { background: transparent; color: var(--label-2); }
      .btn-ghost:hover { color: var(--label-1); background: var(--fill-4); }

      .btn-danger-ghost { background: transparent; color: var(--danger); }
      .btn-danger-ghost:hover { background: var(--danger-soft); color: var(--danger); }

      .btn-destructive {
        background: var(--danger);
        color: #fff;
        background-image: linear-gradient(180deg, rgba(255,255,255,0.12), rgba(255,255,255,0));
      }
      .btn-destructive:hover { filter: brightness(1.06); }

      /* ─── Inputs ─── */
      .input, .textarea {
        width: 100%;
        background: var(--surface);
        color: var(--label-1);
        border: 0.5px solid var(--border-strong);
        border-radius: var(--radius);
        padding: 0.72rem 0.9rem;
        font-family: inherit;
        font-size: 0.97rem;
        letter-spacing: -0.02em;
        box-shadow: inset 0 1px 0 rgba(0,0,0,0.02);
        transition: border-color 0.15s var(--ease), box-shadow 0.15s var(--ease),
          background 0.15s var(--ease);
      }
      [data-theme='dark'] .input,
      [data-theme='dark'] .textarea {
        background: var(--surface-2);
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.03);
      }
      .textarea { resize: vertical; min-height: 88px; line-height: 1.5; }
      .input:focus, .textarea:focus {
        outline: none;
        border-color: var(--accent);
        box-shadow:
          0 0 0 4px var(--accent-soft),
          inset 0 0 0 1px var(--accent);
      }
      .input::placeholder, .textarea::placeholder { color: var(--label-4); }

      .field { display: flex; flex-direction: column; gap: 0.42rem; }
      .field-label {
        font-size: 0.84rem;
        font-weight: 590;
        color: var(--label-1);
        letter-spacing: -0.012em;
      }

      /* ─── Cards / panels ─── */
      .card {
        background: var(--surface);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-sm);
        transition: box-shadow 0.24s var(--ease), transform 0.24s var(--ease);
        position: relative;
      }
      .card-body { padding: 1.35rem 1.45rem; }
      .card-body-tight { padding: 1rem 1.15rem; }
      a.card, button.card { cursor: pointer; }
      a.card:hover, button.card:hover {
        box-shadow: var(--shadow-md);
        transform: translateY(-1px);
      }

      .panel {
        background: var(--surface);
        border-radius: var(--radius-xl);
        box-shadow: var(--shadow-md);
        padding: 2.25rem 2rem;
      }

      /* ─── Misc ─── */
      .divider { height: 0.5px; background: var(--separator); border: 0; margin: 0; }
      .hairline-top    { border-top: 0.5px solid var(--separator); }
      .hairline-bottom { border-bottom: 0.5px solid var(--separator); }

      .link {
        color: var(--accent);
        text-decoration: none;
        font-weight: 500;
      }
      .link:hover { text-decoration: underline; text-underline-offset: 2px; text-decoration-thickness: 1px; }

      .alert {
        padding: 0.78rem 1rem;
        border-radius: var(--radius);
        font-size: 0.89rem;
        font-weight: 500;
        background: var(--accent-soft);
        color: var(--accent);
        box-shadow: var(--shadow-xs);
      }
      .alert-error { background: var(--danger-soft); color: var(--danger); }
      .alert-info  { background: var(--fill-4); color: var(--label-2); }

      .badge {
        display: inline-flex;
        align-items: center;
        padding: 0.12rem 0.52rem;
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: -0.004em;
        border-radius: 980px;
        background: var(--accent);
        color: #fff;
      }
      .badge-soft { background: var(--accent-soft); color: var(--accent); }

      /* ─── Theme picker ─── */
      .theme-picker {
        display: inline-flex;
        background: rgba(0, 0, 0, 0.08);
        border-radius: 980px;
        padding: 2px;
        gap: 0;
      }
      [data-theme='dark'] .theme-picker {
        background: rgba(120, 120, 128, 0.32);
      }
      .theme-picker button {
        background: transparent;
        border: none;
        color: var(--label-2);
        padding: 0.32rem 0.72rem;
        font: inherit;
        font-size: 0.76rem;
        font-weight: 500;
        border-radius: 980px;
        cursor: pointer;
        display: inline-flex; align-items: center; gap: 4px;
        transition: background 0.22s var(--ease), color 0.22s var(--ease),
          box-shadow 0.22s var(--ease);
      }
      .theme-picker button:hover { color: var(--label-1); }
      .theme-picker button[aria-pressed='true'] {
        background: var(--surface);
        color: var(--label-1);
        box-shadow:
          0 0 0 0.5px rgba(0,0,0,0.06),
          0 1px 2px rgba(0,0,0,0.08);
      }
      [data-theme='dark'] .theme-picker button[aria-pressed='true'] {
        background: var(--surface-2);
        box-shadow:
          0 0 0 0.5px rgba(255,255,255,0.08),
          inset 0 1px 0 rgba(255,255,255,0.06);
      }
      .theme-picker svg { width: 12px; height: 12px; }

      /* ─── Hero glow — atmosphere behind big titles ─── */
      .hero-glow { position: relative; isolation: isolate; }
      .hero-glow::before {
        content: '';
        position: absolute;
        inset: -15% -10% -5%;
        z-index: -1;
        background:
          radial-gradient(ellipse 55% 45% at 50% 40%, var(--accent-glow), transparent 65%);
        opacity: 0.9;
        pointer-events: none;
      }

      /* ─── Page wrap ─── */
      .wrap {
        max-width: 880px;
        margin: 0 auto;
        padding: 2.75rem 1.25rem 4rem;
      }

      /* ─── Confirmation dialog ─── */
      dialog.confirm {
        border: none;
        padding: 0;
        background: var(--surface);
        color: var(--label-1);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-lg);
        max-width: 380px;
        width: calc(100% - 2rem);
        font-family: inherit;
      }
      dialog.confirm::backdrop {
        background: rgba(0, 0, 0, 0.36);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
      }
      dialog.confirm[open] { animation: dialogIn 0.26s var(--ease-spring); }
      dialog.confirm[open]::backdrop { animation: backdropIn 0.22s var(--ease); }
      @keyframes dialogIn {
        from { opacity: 0; transform: translateY(8px) scale(0.98); }
        to   { opacity: 1; transform: translateY(0)   scale(1); }
      }
      @keyframes backdropIn { from { opacity: 0; } to { opacity: 1; } }
      .confirm-body-wrap { padding: 1.45rem 1.5rem 1.2rem; }
      .confirm-title {
        font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', system-ui, sans-serif;
        font-weight: 600;
        font-size: 1.06rem;
        letter-spacing: -0.018em;
        text-align: center;
        margin: 0 0 0.35rem;
        color: var(--label-1);
      }
      .confirm-message {
        font-size: 0.89rem;
        color: var(--label-2);
        text-align: center;
        line-height: 1.42;
        margin: 0 0 1.15rem;
      }
      .confirm-actions { display: flex; gap: 0.55rem; }
      .confirm-actions .btn { flex: 1; }

      /* ─── Entry animation ─── */
      @keyframes riseIn {
        from { opacity: 0; transform: translateY(8px); }
        to   { opacity: 1; transform: translateY(0); }
      }
      main > * { animation: riseIn 0.42s var(--ease-spring) both; }
      main > *:nth-child(2) { animation-delay: 0.04s; }
      main > *:nth-child(3) { animation-delay: 0.08s; }
      main > *:nth-child(4) { animation-delay: 0.12s; }

      /* ─── Utility classes bound to Apple labels ─── */
      .text-primary    { color: var(--label-1); }
      .text-secondary  { color: var(--label-2); }
      .text-tertiary   { color: var(--label-3); }
      .text-quaternary { color: var(--label-4); }
      .text-danger     { color: var(--danger); }
      .text-accent     { color: var(--accent); }
      .bg-surface      { background: var(--surface); }
      .bg-surface-2    { background: var(--surface-2); }
      .border-hair     { border: 0.5px solid var(--separator); }
      .tabular         { font-variant-numeric: tabular-nums; }

      /* Respect reduced motion */
      @media (prefers-reduced-motion: reduce) {
        *, *::before, *::after {
          animation-duration: 0.01ms !important;
          transition-duration: 0.01ms !important;
        }
      }
    </style>
  </head>
  <body>
    <%- include('partials/nav') %>
    <main class="wrap">
      <%- body %>
    </main>

    <dialog id="confirm-dialog" class="confirm" aria-labelledby="confirm-title">
      <div class="confirm-body-wrap">
        <h3 id="confirm-title" class="confirm-title">Are you sure?</h3>
        <p id="confirm-message" class="confirm-message"></p>
        <div class="confirm-actions">
          <button type="button" class="btn btn-secondary" data-confirm-action="cancel">Cancel</button>
          <button type="button" class="btn btn-primary" data-confirm-action="ok">Confirm</button>
        </div>
      </div>
    </dialog>

    <script>
      // Theme picker controller.
      (function () {
        var media = window.matchMedia('(prefers-color-scheme: dark)');

        function apply(pref) {
          var resolved = pref === 'system'
            ? (media.matches ? 'dark' : 'light')
            : pref;
          document.documentElement.setAttribute('data-theme', resolved);
          document.documentElement.setAttribute('data-theme-pref', pref);
          try { localStorage.setItem('theme-pref', pref); } catch (e) {}
          document.querySelectorAll('.theme-picker button').forEach(function (b) {
            b.setAttribute('aria-pressed', String(b.dataset.theme === pref));
          });
        }

        document.addEventListener('click', function (e) {
          var btn = e.target.closest('.theme-picker button');
          if (!btn) return;
          apply(btn.dataset.theme);
        });

        if (media.addEventListener) {
          media.addEventListener('change', function () {
            var pref = document.documentElement.getAttribute('data-theme-pref') || 'system';
            if (pref === 'system') apply('system');
          });
        }

        var pref = document.documentElement.getAttribute('data-theme-pref') || 'system';
        document.querySelectorAll('.theme-picker button').forEach(function (b) {
          b.setAttribute('aria-pressed', String(b.dataset.theme === pref));
        });
      })();

      // Timestamp formatter — renders every <time class="ts"> in the user's
      // local timezone with Apple Messages-style smart relative formatting.
      (function () {
        function timePart(d) {
          return d.toLocaleTimeString(undefined, { hour: 'numeric', minute: '2-digit' });
        }

        function smart(d) {
          var now = new Date();
          var diffMs = now - d;
          var diffMin = Math.floor(diffMs / 60000);

          var sameDay = now.toDateString() === d.toDateString();
          var ydObj = new Date(now); ydObj.setDate(ydObj.getDate() - 1);
          var isYesterday = ydObj.toDateString() === d.toDateString();
          var withinWeek = diffMs >= 0 && diffMs < 7 * 86400000;

          if (diffMin < 1 && diffMs >= 0) return 'just now';
          if (diffMin < 60 && diffMs >= 0) return diffMin + ' min ago';
          if (sameDay) return timePart(d);
          if (isYesterday) return 'Yesterday ' + timePart(d);
          if (withinWeek) {
            return d.toLocaleDateString(undefined, { weekday: 'short' }) + ' ' + timePart(d);
          }
          if (d.getFullYear() === now.getFullYear()) {
            return d.toLocaleDateString(undefined, { month: 'short', day: 'numeric' });
          }
          return d.toLocaleDateString(undefined, { year: 'numeric', month: 'short', day: 'numeric' });
        }

        function full(d) {
          return d.toLocaleString(undefined, {
            year: 'numeric', month: 'short', day: 'numeric',
            hour: 'numeric', minute: '2-digit',
            timeZoneName: 'short'
          });
        }

        function renderAll() {
          document.querySelectorAll('time.ts').forEach(function (el) {
            var iso = el.getAttribute('datetime');
            if (!iso) return;
            var d = new Date(iso);
            if (isNaN(d.getTime())) return;
            el.textContent = smart(d);
            el.title = full(d);
          });
        }

        renderAll();
        // Keep relative labels fresh without needing a reload.
        setInterval(renderAll, 60000);
      })();

      // Confirmation dialog.
      (function () {
        var dlg = document.getElementById('confirm-dialog');
        if (!dlg || typeof dlg.showModal !== 'function') return;
        var titleEl   = dlg.querySelector('#confirm-title');
        var msgEl     = dlg.querySelector('#confirm-message');
        var okBtn     = dlg.querySelector('[data-confirm-action="ok"]');
        var cancelBtn = dlg.querySelector('[data-confirm-action="cancel"]');
        var pending = null;

        function open(form) {
          pending = form;
          titleEl.textContent = form.dataset.confirmTitle || 'Are you sure?';
          msgEl.textContent = form.dataset.confirm || '';
          var destructive = form.dataset.confirmDestructive === 'true';
          okBtn.textContent = form.dataset.confirmLabel || (destructive ? 'Delete' : 'Confirm');
          okBtn.className = 'btn ' + (destructive ? 'btn-destructive' : 'btn-primary');
          dlg.showModal();
          (destructive ? cancelBtn : okBtn).focus();
        }

        function close(result) {
          if (!pending) return;
          var form = pending;
          pending = null;
          dlg.close();
          if (result === 'ok') {
            form.dataset.confirmed = 'true';
            form.submit();
          }
        }

        document.addEventListener('submit', function (e) {
          var form = e.target.closest('form[data-confirm]');
          if (!form) return;
          if (form.dataset.confirmed === 'true') return;
          e.preventDefault();
          open(form);
        });

        okBtn.addEventListener('click', function () { close('ok'); });
        cancelBtn.addEventListener('click', function () { close('cancel'); });
        dlg.addEventListener('cancel', function () { close('cancel'); });
        dlg.addEventListener('click', function (e) {
          var r = dlg.getBoundingClientRect();
          var inside = e.clientX >= r.left && e.clientX <= r.right &&
                       e.clientY >= r.top  && e.clientY <= r.bottom;
          if (!inside) close('cancel');
        });
      })();
    </script>
  </body>
</html>
